msgid "Inversión y retorno"
msgstr "Investment and return"

#: templates/automatizaciones.html:120
msgid "Las automatizaciones parten desde"
msgstr "Automations start from"

#: templates/automatizaciones.html:120
msgid "mes"
msgstr "month"

#: templates/automatizaciones.html:120
msgid ""
"para procesos sencillos. Proyectos RPA multi-departamento desde 3.000€ de "
