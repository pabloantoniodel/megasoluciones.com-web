# Megasoluciones Environment Variables
# Copiar este archivo a .env y completar con valores reales

SECRET_KEY=cambia-esto-por-una-clave-secreta-segura

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
DEBUG=False

# Email Configuration (REQUERIDO para envío de emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=info@megasolucion.net
MAIL_PASSWORD=tu-password-app-aqui
MAIL_DEFAULT_SENDER=info@megasolucion.net

# Para Gmail:
# 1. Ir a: https://myaccount.google.com/apppasswords
# 2. Crear "App Password" para "Mail"
# 3. Usar esa contraseña en MAIL_PASSWORD

# Para otros proveedores (SMTP):
# - Outlook/Hotmail: smtp-mail.outlook.com, puerto 587
# - Yahoo: smtp.mail.yahoo.com, puerto 587
# - SMTP personalizado: usa tu servidor SMTP

# Database (opcional para futuras expansiones)
DATABASE_URL=sqlite:///megasoluciones.db

# Google Search Console (meta tag HTML — valor de content= en GSC)
# GSC_VERIFICATION_TOKEN=google1234567890abcdef
# Alternativa: crear gsc-verification.txt en la raíz (ver gsc-verification.example)

# Google Analytics 4
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Alternativa: ga4-id.txt en la raíz del proyecto

# Anti-spam formulario de contacto
# Cloudflare Turnstile: https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITE_KEY=tu_site_key_publica
# TURNSTILE_SECRET_KEY=tu_secret_key
# Alternativa: turnstile-site-key.txt y turnstile-secret-key.txt en la raíz del proyecto

# Akismet (equivalente a Jetpack Anti-spam): https://akismet.com
# AKISMET_API_KEY=tu_api_key_akismet
# Alternativa: akismet-key.txt en la raíz del proyecto

# Posts automáticos desde YouTube + panel de administración
# OPENAI_API_KEY=sk-...            # API de OpenAI para redactar los posts (alternativa: openai-key.txt)
# ADMIN_PASSWORD=contraseña_segura # Acceso al panel /admin (alternativa: admin-password.txt)
# YT_WORKER_INTERVAL_MIN=30        # Frecuencia de chequeo de canales (minutos)
# NOTIFY_EMAIL=info@megasolucion.net

# LinkedIn — publicación automática en página de empresa
# Requiere app en developers.linkedin.com con Community Management API
# LINKEDIN_ACCESS_TOKEN=...
# LINKEDIN_REFRESH_TOKEN=...
# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...
# LINKEDIN_ORG_ID=12345678
# LINKEDIN_API_VERSION=202501
# LINKEDIN_WORKER_INTERVAL_MIN=15
# Alternativa: archivos linkedin-access-token.txt, linkedin-org-id.txt, etc. en la raíz del proyecto

# Proxy para transcripciones (YouTube bloquea IPs de datacenter)
# Opción A (recomendada): proxies residenciales de Webshare — https://www.webshare.io
# WEBSHARE_PROXY_USERNAME=usuario
# WEBSHARE_PROXY_PASSWORD=contraseña
# Opción B: cualquier proxy http/socks5
# YT_PROXY=http://usuario:contraseña@host:puerto

# Twitter/X — publicar tweets con imagen (OAuth 1.0a en developer.twitter.com)
# TWITTER_API_KEY=...
# TWITTER_API_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_TOKEN_SECRET=...
# Alternativa: twitter-api-key.txt, x-access-token.txt, etc.

# Instagram Graph API — cuenta Business vinculada a página de Facebook
# INSTAGRAM_ACCESS_TOKEN=token_larga_duracion_pagina
# INSTAGRAM_USER_ID=17841400000000000
# Alternativa: instagram-access-token.txt, instagram-user-id.txt
# SITE_BASE_URL=https://megasolucion.es
