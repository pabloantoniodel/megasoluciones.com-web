# Megasoluciones Environment Variables
# Copiar este archivo a .env y completar con valores reales

SECRET_KEY=cambia-esto-por-una-clave-secreta-segura

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
DEBUG=False

# Email Configuration (REQUERIDO para envío de emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=info@megasolucion.net
MAIL_PASSWORD=tu-password-app-aqui
MAIL_DEFAULT_SENDER=info@megasolucion.net

# Para Gmail:
# 1. Ir a: https://myaccount.google.com/apppasswords
# 2. Crear "App Password" para "Mail"
# 3. Usar esa contraseña en MAIL_PASSWORD

# Para otros proveedores (SMTP):
# - Outlook/Hotmail: smtp-mail.outlook.com, puerto 587
# - Yahoo: smtp.mail.yahoo.com, puerto 587
# - SMTP personalizado: usa tu servidor SMTP

# Database (opcional para futuras expansiones)
DATABASE_URL=sqlite:///megasoluciones.db

# Google Search Console (meta tag HTML — valor de content= en GSC)
# GSC_VERIFICATION_TOKEN=google1234567890abcdef
# Alternativa: crear gsc-verification.txt en la raíz (ver gsc-verification.example)

# Anti-spam formulario de contacto
# Cloudflare Turnstile: https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITE_KEY=tu_site_key_publica
# TURNSTILE_SECRET_KEY=tu_secret_key
# Alternativa: turnstile-site-key.txt y turnstile-secret-key.txt en la raíz del proyecto

# Akismet (equivalente a Jetpack Anti-spam): https://akismet.com
# AKISMET_API_KEY=tu_api_key_akismet
# Alternativa: akismet-key.txt en la raíz del proyecto
