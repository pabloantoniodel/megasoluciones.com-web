# Megasoluciones Environment Variables
# Copiar este archivo a .env y completar con valores reales

SECRET_KEY=cambia-esto-por-una-clave-secreta-segura

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
DEBUG=False

# Email Configuration (opcional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-password-app

# Database (opcional para futuras expansiones)
DATABASE_URL=sqlite:///megasoluciones.db
